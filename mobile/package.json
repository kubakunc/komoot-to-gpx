{
  "name": "export-gpx-for-komoot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "cap:sync": "pnpm build && cap sync android",
    "cap:open": "cap open android",
    "android:build": "pnpm cap:sync && cd android && ./gradlew assembleDebug",
    "android:bundle": "pnpm cap:sync && cd android && ./gradlew bundleRelease"
  },
  "dependencies": {
    "@capacitor-community/admob": "^6.0.0",
    "@capacitor-community/in-app-review": "6.0.0",
    "@capacitor-firebase/analytics": "6.3.1",
    "@capacitor-firebase/crashlytics": "6.3.1",
    "@capacitor/android": "^6.1.0",
    "@capacitor/core": "^6.1.0",
    "@capacitor/filesystem": "^6.0.0",
    "@capacitor/preferences": "^6.0.0",
    "@fontsource-variable/inter": "^5.2.0",
    "leaflet": "^1.9.4"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.0",
    "@sveltejs/adapter-static": "^3.0.0",
    "@sveltejs/kit": "^2.5.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@types/leaflet": "^1.9.0",
    "@types/node": "^22.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
